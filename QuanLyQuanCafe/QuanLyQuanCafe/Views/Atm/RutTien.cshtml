@model RutTienViewModel
@{
    ViewData["Title"] = "Rút tiền";
}
<div class="container container-main py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h1 class="h4 fw-bold mb-1">Yêu cầu nhập số tiền</h1>
                    <p class="text-muted small mb-4">Thẻ @Model.SoThe</p>
                    <form asp-action="RutTien" method="post">
                        <input type="hidden" asp-for="SoThe" />
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="SoTien" class="form-label fw-semibold"></label>
                            <input asp-for="SoTien" class="form-control form-control-lg" type="number" step="10000" min="10000" />
                            <span asp-validation-for="SoTien" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-success w-100 mb-2">Rút tiền</button>
                        <a asp-action="Menu" class="btn btn-outline-secondary w-100">Quay lại menu</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}