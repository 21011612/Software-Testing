@model MenuAtmViewModel
@{
    ViewData["Title"] = "Lựa chọn giao dịch";
}
<div class="container container-main py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h1 class="h4 fw-bold mb-1">Danh sách lựa chọn</h1>
                    <p class="text-muted small mb-4">Xin chào <strong>@Model.ChuThe</strong> · Thẻ @Model.SoThe</p>
                    <form asp-action="Menu" method="post" class="d-grid gap-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" name="luaChon" value="@LuaChonAtm.KiemTraSoDu" class="btn btn-outline-primary btn-lg text-start">
                            <i class="bi bi-wallet2 me-2"></i> Kiểm tra số dư
                        </button>
                        <button type="submit" name="luaChon" value="@LuaChonAtm.RutTien" class="btn btn-outline-success btn-lg text-start">
                            <i class="bi bi-cash-stack me-2"></i> Rút tiền
                        </button>
                        <button type="submit" name="luaChon" value="@LuaChonAtm.Huy" class="btn btn-outline-secondary btn-lg text-start">
                            <i class="bi bi-x-circle me-2"></i> Hủy giao dịch
                        </button>
                    </form>
                    <form asp-action="KetThuc" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link btn-sm text-muted p-0">Kết thúc — in hóa đơn &amp; trả thẻ</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>