@model NhapTheViewModel
@{
    ViewData["Title"] = "Cây ATM";
}
<div class="container container-main py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h1 class="h4 fw-bold mb-1"><i class="bi bi-bank2 text-primary me-2"></i>Cây ATM</h1>
                    <p class="text-muted small mb-4">Nhập thẻ để bắt đầu (demo: <code>1234567890</code>, <code>0987654321</code>)</p>
                    <form asp-action="NhapThe" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="SoThe" class="form-label fw-semibold"></label>
                            <input asp-for="SoThe" class="form-control form-control-lg" autocomplete="off" placeholder="Số thẻ" />
                            <span asp-validation-for="SoThe" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Nhập thẻ</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}