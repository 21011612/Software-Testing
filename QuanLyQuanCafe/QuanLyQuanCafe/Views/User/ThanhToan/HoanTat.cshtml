@model ThanhToanViewModel
@{
    ViewData["Title"] = $"Hóa đơn #{Model.MaHD}";
}

<div class="success-hero">
    <div class="success-icon"><i class="bi bi-check-lg"></i></div>
    <h1 class="page-header-title">Thanh toán thành công!</h1>
    <p class="text-muted mb-2">Hóa đơn <strong>#@Model.MaHD</strong> · @Model.TrangThai</p>
    <p class="price-tag fs-2 mb-4">@Model.TongThanhToan.ToString("N0") đ</p>
    <div class="d-flex flex-wrap gap-2 justify-content-center">
        <a asp-controller="ThucDon" asp-action="Index" class="btn btn-tooru btn-lg"><i class="bi bi-cup-straw me-1"></i> Gọi thêm món</a>
        <a asp-controller="DonHang" asp-action="LichSu" class="btn btn-outline-tooru btn-lg">Lịch sử đơn</a>
    </div>
</div>