@{
    ViewData["Title"] = "Giỏ hàng";
    ViewData["PageTitle"] = "Giỏ hàng của bạn";
    ViewData["PageDesc"] = "Kiểm tra món trước khi đặt hàng";
    var items = ViewBag.Items as List<GioHangItem> ?? new();
    var tong = (decimal)(ViewBag.TongTien ?? 0m);
}

<partial name="_PageHeader" />

@if (items.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon"><i class="bi bi-bag"></i></div>
        <h2 class="h5">Giỏ hàng đang trống</h2>
        <p class="text-muted mb-3">Hãy chọn vài món từ thực đơn nhé!</p>
        <a asp-controller="ThucDon" asp-action="Index" class="btn btn-tooru">Xem thực đơn</a>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="panel">
                <div class="table-responsive">
                    <table class="table table-modern align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Món</th>
                                <th>Đơn giá</th>
                                <th>Số lượng</th>
                                <th>Thành tiền</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var i in items)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="@ImageHelper.ToUrl(i.HinhAnh)" alt="" class="cart-img" />
                                            <div>
                                                <strong>@i.TenSP</strong>
                                                @if (!string.IsNullOrEmpty(i.GhiChu))
                                                {
                                                    <br /><small class="text-muted"><i class="bi bi-chat-left-text me-1"></i>@i.GhiChu</small>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td>@i.DonGia.ToString("N0") đ</td>
                                    <td>
                                        <div class="cart-qty-stepper">
                                            <form asp-action="TangGiamGioHang" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="maSp" value="@i.MaSP" />
                                                <input type="hidden" name="delta" value="-1" />
                                                <button type="submit" class="btn btn-qty" title="Giảm" aria-label="Giảm số lượng">
                                                    <i class="bi bi-dash-lg"></i>
                                                </button>
                                            </form>
                                            <span class="cart-qty-value" aria-live="polite">@i.SoLuong</span>
                                            <form asp-action="TangGiamGioHang" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="maSp" value="@i.MaSP" />
                                                <input type="hidden" name="delta" value="1" />
                                                <button type="submit" class="btn btn-qty" title="Tăng" aria-label="Tăng số lượng" @(i.SoLuong >= 99 ? "disabled" : null)>
                                                    <i class="bi bi-plus-lg"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                    <td class="fw-bold price-tag">@i.ThanhTien.ToString("N0") đ</td>
                                    <td>
                                        <form asp-action="XoaGioHang" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="maSp" value="@i.MaSP" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" title="Xóa"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="cart-summary">
                <p class="small opacity-75 mb-1">Tổng cộng (@items.Sum(x => x.SoLuong) món)</p>
                <p class="price-tag mb-3">@tong.ToString("N0") đ</p>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-action="DatHang" class="btn btn-tooru btn-lg w-100">
                        <i class="bi bi-arrow-right-circle me-1"></i> Đặt hàng
                    </a>
                }
                else
                {
                    <a asp-controller="TaiKhoan" asp-action="DangNhap" asp-route-returnUrl="@Url.Action("GioHang")" class="btn btn-tooru btn-lg w-100">
                        Đăng nhập để đặt hàng
                    </a>
                }
            </div>
        </div>
    </div>
}