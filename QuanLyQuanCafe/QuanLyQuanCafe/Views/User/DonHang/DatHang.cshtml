@model DatHangViewModel
@{
    ViewData["Title"] = "Đặt hàng";
    ViewData["PageTitle"] = "Xác nhận đặt hàng";
    ViewData["PageDesc"] = "Chọn loại đơn, bàn và khuyến mãi (nếu có)";
    var items = ViewBag.Items as List<GioHangItem> ?? new();
    var tong = (decimal)(ViewBag.TongTien ?? 0m);
    var bans = ViewBag.Bans as IEnumerable<Ban>;
    var kms = ViewBag.KhuyenMais as IEnumerable<KhuyenMai>;
}

<partial name="_PageHeader" />

<div class="row g-4">
    <div class="col-lg-5">
        <div class="panel">
            <div class="panel-header"><i class="bi bi-bag-check"></i> Giỏ hàng (@items.Count món)</div>
            <div class="panel-body">
                @foreach (var i in items)
                {
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span>@i.TenSP <small class="text-muted">×@i.SoLuong</small></span>
                        <span class="fw-semibold">@i.ThanhTien.ToString("N0") đ</span>
                    </div>
                }
                <hr />
                <div class="d-flex justify-content-between align-items-center pt-2">
                    <span class="fw-semibold text-muted">Tạm tính</span>
                    <span class="price-tag fs-4 mb-0">@tong.ToString("N0") đ</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <form asp-action="DatHang" method="post" class="panel">
            @Html.AntiForgeryToken()
            <div class="panel-header"><i class="bi bi-pencil-square"></i> Thông tin đơn</div>
            <div class="panel-body">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="LoaiDon" class="form-label fw-semibold"></label>
                        <select asp-for="LoaiDon" class="form-select">
                            <option value="Tại quán">Tại quán</option>
                            <option value="Mang về">Mang về</option>
                            <option value="Giao hàng">Giao hàng</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MaBan" class="form-label fw-semibold"></label>
                        <select asp-for="MaBan" class="form-select">
                            <option value="">— Không chọn bàn —</option>
                            @foreach (var b in bans ?? Enumerable.Empty<Ban>())
                            {
                                <option value="@b.MaBan">@b.TenBan · @b.KhuVuc</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label asp-for="MaKM" class="form-label fw-semibold"></label>
                        <select asp-for="MaKM" class="form-select">
                            <option value="">— Không dùng khuyến mãi —</option>
                            @foreach (var k in kms ?? Enumerable.Empty<KhuyenMai>())
                            {
                                <option value="@k.MaKM">@k.TenKM (từ @k.DieuKienToiThieu.ToString("N0") đ)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TenKhach" class="form-label fw-semibold"></label>
                        <input asp-for="TenKhach" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SDT" class="form-label fw-semibold"></label>
                        <input asp-for="SDT" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="DiaChiGiao" class="form-label fw-semibold"></label>
                        <input asp-for="DiaChiGiao" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="GhiChu" class="form-label fw-semibold"></label>
                        <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <button type="submit" class="btn btn-tooru btn-lg w-100 mt-4">
                    <i class="bi bi-send me-1"></i> Tạo hóa đơn & thanh toán
                </button>
            </div>
        </form>
    </div>
</div>