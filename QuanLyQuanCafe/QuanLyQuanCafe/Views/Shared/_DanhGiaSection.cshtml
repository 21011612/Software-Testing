@model SanPham
@using QuanLyQuanCafe.ViewModels
@{
    var tongHop = ViewBag.DanhGiaTongHop as SanPhamDanhGiaTongHop;
    var list = ViewBag.DanhGiaList as List<DanhGiaHienThiViewModel> ?? [];
    var cuaToi = ViewBag.DanhGiaCuaToi as DanhGiaBinhLuan;
    var maKh = ViewBag.MaKhachHang as int?;
    var hoTenKhach = ViewBag.HoTenKhach as string;
    var diem = tongHop?.DiemTrungBinh ?? 0;
    var soLuot = tongHop?.SoDanhGia ?? 0;
    var form = new DanhGiaFormViewModel
    {
        MaSP = Model.MaSP,
        SoSao = cuaToi?.SoSao ?? (byte)5,
        NoiDung = cuaToi?.NoiDung ?? "",
        HoTenHienThi = hoTenKhach
    };
}

<section class="review-section mt-5" id="danh-gia">
    <div class="section-head section-head-start mb-4">
        <h2 class="h4 mb-1">Đánh giá &amp; bình luận</h2>
        <partial name="_StarRating" model="@(new StarRatingViewModel { Diem = diem, SoLuot = soLuot })" />
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="review-form-panel">
                <h3 class="h6 mb-3">@(cuaToi != null ? "Cập nhật đánh giá của bạn" : "Viết đánh giá")</h3>
                <form asp-controller="DanhGia" asp-action="Gui" method="post" class="review-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MaSP" value="@form.MaSP" />

                    <label class="form-label fw-semibold">Số sao</label>
                    <div class="star-input mb-3" id="starInput" data-value="@form.SoSao">
                        @for (byte s = 1; s <= 5; s++)
                        {
                            <button type="button" class="star-input-btn" data-star="@s" aria-label="@s sao">
                                <i class="bi bi-star-fill"></i>
                            </button>
                        }
                        <input type="hidden" name="SoSao" id="soSaoHidden" value="@form.SoSao" />
                        <span class="star-input-label" id="starInputLabel">@form.SoSao/5 sao</span>
                    </div>

                    @if (!maKh.HasValue)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="hoTenBl">Họ tên hiển thị</label>
                            <input type="text" class="form-control" id="hoTenBl" name="HoTenHienThi" maxlength="100" placeholder="Tên của bạn" value="@form.HoTenHienThi" required />
                            <div class="form-text">Hoặc <a asp-controller="TaiKhoan" asp-action="DangNhap">đăng nhập</a> để gắn với tài khoản.</div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="noiDungBl">Bình luận</label>
                        <textarea class="form-control" id="noiDungBl" name="NoiDung" rows="4" maxlength="500" placeholder="Chia sẻ vị, không gian phục vụ..." required>@form.NoiDung</textarea>
                    </div>

                    <button type="submit" class="btn btn-tooru w-100">
                        <i class="bi bi-send me-1"></i> @(cuaToi != null ? "Cập nhật" : "Gửi đánh giá")
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-7">
            @if (list.Count == 0)
            {
                <div class="review-empty">
                    <i class="bi bi-chat-square-heart"></i>
                    <p class="mb-0">Chưa có bình luận. Hãy là người đầu tiên đánh giá món này!</p>
                </div>
            }
            else
            {
                <div class="review-list">
                    @foreach (var bl in list)
                    {
                        <article class="review-item">
                            <div class="review-item-head">
                                <strong>@bl.HoTenHienThi</strong>
                                @if (bl.LaCuaToi)
                                {
                                    <span class="badge bg-warning text-dark">Bạn</span>
                                }
                                <span class="review-item-date">@bl.NgayTao.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="mb-1">
                                @Html.Raw(StarRatingHelper.RenderStars(bl.SoSao, "star-rating--sm"))
                            </div>
                            <p class="review-item-text mb-0">@bl.NoiDung</p>
                        </article>
                    }
                </div>
            }
        </div>
    </div>
</section>