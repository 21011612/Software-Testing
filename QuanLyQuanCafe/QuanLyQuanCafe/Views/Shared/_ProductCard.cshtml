@model SanPham
@using QuanLyQuanCafe.ViewModels
@{
    var showActions = ViewData["ShowCartActions"] as bool? ?? false;
    var danhGiaDict = ViewBag.DanhGiaTongHop as Dictionary<int, SanPhamDanhGiaTongHop>;
    SanPhamDanhGiaTongHop? dg = null;
    if (danhGiaDict != null && danhGiaDict.ContainsKey(Model.MaSP))
    {
        dg = danhGiaDict[Model.MaSP];
    }
}

<div class="card card-product">
    <div class="card-product-img-wrap">
        <img src="@ImageHelper.ToUrl(Model.HinhAnh)" alt="@Model.TenSP" loading="lazy" />
        <div class="card-product-overlay">
            <span class="badge badge-loai">@Model.LoaiSanPham?.TenLoai</span>
        </div>
    </div>
    <div class="card-body d-flex flex-column">
        <h3 class="h6 card-product-title">@Model.TenSP</h3>
        @if (dg != null && dg.SoDanhGia > 0)
        {
            <div class="card-product-rating mb-1">
                <partial name="_StarRating" model="@(new StarRatingViewModel { Diem = dg.DiemTrungBinh, SoLuot = dg.SoDanhGia, SizeClass = "star-rating--xs" })" />
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.MoTa) && showActions)
        {
            <p class="small text-muted flex-grow-1 mb-2">@(Model.MoTa.Length > 55 ? Model.MoTa[..55] + "…" : Model.MoTa)</p>
        }
        <p class="price-tag mb-2">
            @Model.Gia.ToString("N0") đ
            <span class="small fw-normal text-muted">/ @Model.KichCo</span>
        </p>
        @if (showActions)
        {
            <form asp-controller="ThucDon" asp-action="ThemGioHang" method="post" class="mt-auto">
                @Html.AntiForgeryToken()
                <input type="hidden" name="maSp" value="@Model.MaSP" />
                <input type="hidden" name="tenSp" value="@Model.TenSP" />
                <input type="hidden" name="hinhAnh" value="@Model.HinhAnh" />
                <input type="hidden" name="donGia" value="@Model.Gia" />
                <div class="d-flex gap-2">
                    <a asp-controller="ThucDon" asp-action="ChiTiet" asp-route-id="@Model.MaSP" class="btn btn-sm btn-outline-tooru flex-grow-1">Chi tiết</a>
                    <button type="submit" class="btn btn-sm btn-tooru flex-grow-1"><i class="bi bi-bag-plus me-1"></i>Thêm vào giỏ</button>
                </div>
            </form>
        }
        else
        {
            <a asp-controller="ThucDon" asp-action="ChiTiet" asp-route-id="@Model.MaSP" class="btn btn-sm btn-tooru w-100 mt-auto">Xem món</a>
        }
    </div>
</div>