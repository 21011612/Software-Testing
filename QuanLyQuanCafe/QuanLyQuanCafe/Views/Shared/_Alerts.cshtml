@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-tooru alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-info alert-tooru alert-dismissible fade show" role="alert">
        <i class="bi bi-info-circle-fill me-2"></i>@TempData["Info"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null || TempData["ReviewError"] != null)
{
    <div class="alert alert-danger alert-tooru alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@(TempData["Error"] ?? TempData["ReviewError"])
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}