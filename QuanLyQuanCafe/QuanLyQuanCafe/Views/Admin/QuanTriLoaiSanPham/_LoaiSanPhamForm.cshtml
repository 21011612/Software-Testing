@model LoaiSanPhamAdminViewModel
@{ var isEdit = Model.MaLoai > 0; }
<form asp-action="@(isEdit ? "Sua" : "Them")" method="post">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="MaLoai" /> }
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="TenLoai" class="form-label"></label><input asp-for="TenLoai" class="form-control" /><span asp-validation-for="TenLoai" class="text-danger small"></span></div>
        <div class="col-md-3"><label asp-for="ThuTuHienThi" class="form-label"></label><input asp-for="ThuTuHienThi" class="form-control" type="number" /></div>
        <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input asp-for="TrangThai" class="form-check-input" /><label asp-for="TrangThai" class="form-check-label"></label></div></div>
        <div class="col-12"><label asp-for="MoTa" class="form-label"></label><textarea asp-for="MoTa" class="form-control" rows="2"></textarea></div>
        <div class="col-12"><label asp-for="HinhAnh" class="form-label"></label><input asp-for="HinhAnh" class="form-control" placeholder="images/..." /></div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-admin-primary"><i class="bi bi-check-lg me-1"></i> Lưu</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>