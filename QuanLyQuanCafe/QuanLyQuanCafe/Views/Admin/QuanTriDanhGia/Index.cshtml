@model IEnumerable<QuanTriDanhGiaRowViewModel>
@{
    ViewData["Title"] = "Bình luận & đánh giá";
    var tuKhoa = ViewBag.TuKhoa as string;
    var locAn = ViewBag.LocAn as bool? ?? false;
}

<div class="admin-page-toolbar">
    <h1 class="admin-page-title">Bình luận &amp; đánh giá</h1>
</div>

<form method="get" class="row g-2 mb-3 align-items-end">
    <div class="col-md-5">
        <label class="form-label small">Tìm kiếm</label>
        <input type="search" name="q" value="@tuKhoa" class="form-control" placeholder="Tên khách, món, nội dung..." />
    </div>
    <div class="col-md-3">
        <div class="form-check mt-4">
            <input class="form-check-input" type="checkbox" name="an" value="true" id="locAn" @(locAn ? "checked" : "") />
            <label class="form-check-label" for="locAn">Chỉ bình luận đang ẩn</label>
        </div>
    </div>
    <div class="col-md-4">
        <button type="submit" class="btn btn-admin-primary me-1">Lọc</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
    </div>
</form>

<div class="admin-table-wrap">
    <div class="table-responsive">
        <table class="table admin-table mb-0">
            <thead>
                <tr>
                    <th>Món</th>
                    <th>Khách</th>
                    <th>Sao</th>
                    <th>Nội dung</th>
                    <th>Thời gian</th>
                    <th>TT</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">Chưa có bình luận.</td></tr>
                }
                @foreach (var bl in Model)
                {
                    <tr class="@(!bl.TrangThai ? "table-secondary" : "")">
                        <td>
                            <a asp-controller="ThucDon" asp-action="ChiTiet" asp-route-id="@bl.MaSP" target="_blank" rel="noopener">@bl.TenSP</a>
                        </td>
                        <td>@bl.HoTenHienThi</td>
                        <td class="text-nowrap">
                            @Html.Raw(StarRatingHelper.RenderStars(bl.SoSao, "star-rating--sm"))
                        </td>
                        <td class="small" style="max-width:280px">@bl.NoiDung</td>
                        <td class="small text-nowrap">@bl.NgayTao.ToString("dd/MM/yy HH:mm")</td>
                        <td>
                            <span class="badge @(bl.TrangThai ? "bg-success" : "bg-secondary")">@(bl.TrangThai ? "Hiện" : "Ẩn")</span>
                        </td>
                        <td class="text-end text-nowrap">
                            <form asp-action="DoiTrangThai" asp-route-id="@bl.MaDG" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="@(bl.TrangThai ? "Ẩn" : "Hiện")">
                                    <i class="bi @(bl.TrangThai ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </form>
                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="Xoa" asp-route-id="@bl.MaDG" method="post" class="d-inline" onsubmit="return confirm('Xóa bình luận này?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>