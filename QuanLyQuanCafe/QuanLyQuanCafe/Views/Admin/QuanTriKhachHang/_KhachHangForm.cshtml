@model KhachHangAdminViewModel
@{
    var hangs = new[] { "Thường", "Bạc", "Vàng", "Kim Cương" };
    var isEdit = Model.MaKH > 0;
}
<form asp-action="@(isEdit ? "Sua" : "Them")" method="post">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="MaKH" /> }
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="HoTen" class="form-label"></label><input asp-for="HoTen" class="form-control" /><span asp-validation-for="HoTen" class="text-danger small"></span></div>
        <div class="col-md-6"><label asp-for="SDT" class="form-label"></label><input asp-for="SDT" class="form-control" /><span asp-validation-for="SDT" class="text-danger small"></span></div>
        <div class="col-md-6"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="NgaySinh" class="form-label"></label><input asp-for="NgaySinh" class="form-control" type="date" /></div>
        <div class="col-12"><label asp-for="DiaChi" class="form-label"></label><input asp-for="DiaChi" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="DiemTichLuy" class="form-label"></label><input asp-for="DiemTichLuy" class="form-control" type="number" min="0" /></div>
        <div class="col-md-6"><label asp-for="HangThanhVien" class="form-label"></label><select asp-for="HangThanhVien" class="form-select">@foreach (var h in hangs) { <option value="@h">@h</option> }</select></div>
        <div class="col-12"><label asp-for="GhiChu" class="form-label"></label><textarea asp-for="GhiChu" class="form-control" rows="2"></textarea></div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-admin-primary"><i class="bi bi-check-lg me-1"></i> Lưu</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>