@model NhanVienAdminViewModel
@{
    var gioiTinhs = new[] { "Nam", "Nữ", "Khác" };
    var isEdit = Model.MaNV > 0;
}
<form asp-action="@(isEdit ? "Sua" : "Them")" method="post">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="MaNV" /> }
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="HoTen" class="form-label"></label><input asp-for="HoTen" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="ChucVu" class="form-label"></label><input asp-for="ChucVu" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="SDT" class="form-label"></label><input asp-for="SDT" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="GioiTinh" class="form-label"></label><select asp-for="GioiTinh" class="form-select"><option value="">—</option>@foreach (var g in gioiTinhs) { <option value="@g">@g</option> }</select></div>
        <div class="col-md-6"><label asp-for="NgaySinh" class="form-label"></label><input asp-for="NgaySinh" class="form-control" type="date" /></div>
        <div class="col-12"><label asp-for="DiaChi" class="form-label"></label><input asp-for="DiaChi" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="NgayVaoLam" class="form-label"></label><input asp-for="NgayVaoLam" class="form-control" type="date" /></div>
        <div class="col-md-6"><label asp-for="LuongCoBan" class="form-label"></label><input asp-for="LuongCoBan" class="form-control" type="number" min="0" step="100000" /></div>
        <div class="col-12"><div class="form-check"><input asp-for="TrangThai" class="form-check-input" /><label asp-for="TrangThai" class="form-check-label"></label></div></div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-admin-primary"><i class="bi bi-check-lg me-1"></i> Lưu</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>