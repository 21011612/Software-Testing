@model IEnumerable<NhaCungCap>
@{ ViewData["Title"] = "Nhà cung cấp"; }
<div class="admin-page-toolbar">
    <h1 class="admin-page-title">Nhà cung cấp</h1>
    <a asp-action="Them" class="btn btn-admin-primary"><i class="bi bi-plus-lg me-1"></i> Thêm NCC</a>
</div>
<div class="admin-table-wrap">
    <table class="table admin-table mb-0">
        <thead><tr><th>Tên</th><th>SĐT</th><th>Liên hệ</th><th>TT</th><th class="text-end"></th></tr></thead>
        <tbody>
            @foreach (var n in Model)
            {
                <tr>
                    <td class="fw-semibold">@n.TenNCC</td>
                    <td>@(n.SDT ?? "—")</td>
                    <td>@(n.NguoiLienHe ?? "—")</td>
                    <td>@(n.TrangThai ? "Hoạt động" : "Ngừng")</td>
                    <td class="text-end text-nowrap">
                        <a asp-action="Sua" asp-route-id="@n.MaNCC" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Xoa" asp-route-id="@n.MaNCC" method="post" class="d-inline" onsubmit="return confirm('Xóa @n.TenNCC?');">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>