@model BanAdminViewModel
@{
    var trangThais = new[] { "Trống", "Đang phục vụ", "Đã đặt trước", "Bảo trì" };
    var isEdit = Model.MaBan > 0;
}

<form asp-action="@(isEdit ? "SuaBan" : "ThemBan")" method="post">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="MaBan" /> }
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="TenBan" class="form-label"></label>
            <input asp-for="TenBan" class="form-control" />
            <span asp-validation-for="TenBan" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="KhuVuc" class="form-label"></label>
            <input asp-for="KhuVuc" class="form-control" list="khuVucList" />
            <datalist id="khuVucList">
                <option value="Tầng trệt" />
                <option value="Tầng 2" />
                <option value="Sân vườn" />
            </datalist>
        </div>
        <div class="col-md-6">
            <label asp-for="SoCho" class="form-label"></label>
            <input asp-for="SoCho" class="form-control" type="number" min="1" max="20" />
        </div>
        <div class="col-md-6">
            <label asp-for="TrangThai" class="form-label"></label>
            <select asp-for="TrangThai" class="form-select">
                @foreach (var tt in trangThais)
                {
                    <option value="@tt">@tt</option>
                }
            </select>
        </div>
        <div class="col-12">
            <label asp-for="GhiChu" class="form-label"></label>
            <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-admin-primary"><i class="bi bi-check-lg me-1"></i> Lưu</button>
        <a asp-action="Ban" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>