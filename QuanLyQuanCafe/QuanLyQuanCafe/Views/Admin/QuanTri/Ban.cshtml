@model IEnumerable<Ban>
@{
    ViewData["Title"] = "Quản lý bàn";
}

<div class="admin-page-toolbar">
    <h1 class="admin-page-title">Quản lý bàn</h1>
    <a asp-action="ThemBan" class="btn btn-admin-primary"><i class="bi bi-plus-lg me-1"></i> Thêm bàn</a>
</div>

<div class="admin-table-wrap">
    <div class="table-responsive">
        <table class="table admin-table">
            <thead>
                <tr>
                    <th>Tên bàn</th>
                    <th>Khu vực</th>
                    <th>Số chỗ</th>
                    <th>Trạng thái</th>
                    <th>Ghi chú</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td><strong>@b.TenBan</strong></td>
                        <td>@b.KhuVuc</td>
                        <td>@b.SoCho</td>
                        <td>
                            <span class="badge @(b.TrangThai == "Trống" ? "bg-success" : b.TrangThai == "Đang phục vụ" ? "bg-warning text-dark" : "bg-info")">
                                @b.TrangThai
                            </span>
                        </td>
                        <td class="small text-muted">@(b.GhiChu ?? "—")</td>
                        <td class="text-end text-nowrap">
                            <a asp-action="SuaBan" asp-route-id="@b.MaBan" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Sửa</a>
                            <form asp-action="XoaBan" asp-route-id="@b.MaBan" method="post" class="d-inline" onsubmit="return confirm('Xóa bàn @b.TenBan?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>