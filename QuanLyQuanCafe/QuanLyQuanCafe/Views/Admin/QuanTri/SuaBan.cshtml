@model BanAdminViewModel
@{
    ViewData["Title"] = "Sửa bàn";
}

<div class="admin-page-toolbar">
    <h1 class="admin-page-title">Sửa bàn #@Model.MaBan</h1>
    <a asp-action="Ban" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
</div>

<div class="admin-form-card">
    <partial name="_BanForm" model="Model" />
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}