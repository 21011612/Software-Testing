@model CongThucAdminViewModel
@{ var isEdit = Model.MaCongThuc > 0; }
<form asp-action="@(isEdit ? "Sua" : "Them")" method="post">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="MaCongThuc" /> }
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="MaSP" class="form-label">Sản phẩm</label><select asp-for="MaSP" class="form-select" asp-items="ViewBag.SanPhams"></select></div>
        <div class="col-md-6"><label asp-for="MaNL" class="form-label">Nguyên liệu</label><select asp-for="MaNL" class="form-select" asp-items="ViewBag.NguyenLieus"></select></div>
        <div class="col-md-4"><label asp-for="SoLuongCan" class="form-label"></label><input asp-for="SoLuongCan" class="form-control" type="number" step="0.001" /></div>
    </div>
    <div class="mt-4 d-flex gap-2"><button type="submit" class="btn btn-admin-primary">Lưu</button><a asp-action="Index" class="btn btn-outline-secondary">Hủy</a></div>
</form>