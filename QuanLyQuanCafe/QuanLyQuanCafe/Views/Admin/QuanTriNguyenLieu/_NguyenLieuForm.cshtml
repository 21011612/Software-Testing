@model NguyenLieuAdminViewModel
@{ var isEdit = Model.MaNL > 0; }
<form asp-action="@(isEdit ? "Sua" : "Them")" method="post">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="MaNL" /> }
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="TenNL" class="form-label"></label><input asp-for="TenNL" class="form-control" /><span asp-validation-for="TenNL" class="text-danger small"></span></div>
        <div class="col-md-3"><label asp-for="DonViTinh" class="form-label"></label><input asp-for="DonViTinh" class="form-control" /></div>
        <div class="col-md-3"><label asp-for="SoLuongTon" class="form-label"></label><input asp-for="SoLuongTon" class="form-control" type="number" step="0.001" /></div>
        <div class="col-md-6"><label asp-for="GiaNhapTrungBinh" class="form-label"></label><input asp-for="GiaNhapTrungBinh" class="form-control" type="number" /></div>
        <div class="col-md-6"><label asp-for="MaNCC" class="form-label"></label><select asp-for="MaNCC" class="form-select" asp-items="ViewBag.NhaCungCaps"><option value="">—</option></select></div>
    </div>
    <div class="mt-4 d-flex gap-2"><button type="submit" class="btn btn-admin-primary">Lưu</button><a asp-action="Index" class="btn btn-outline-secondary">Hủy</a></div>
</form>