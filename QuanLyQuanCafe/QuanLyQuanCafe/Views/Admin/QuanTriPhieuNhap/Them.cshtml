@model PhieuNhapAdminViewModel
@{ ViewData["Title"] = "Tạo phiếu nhập"; }
<div class="admin-page-toolbar"><h1 class="admin-page-title">Tạo phiếu nhập (header)</h1><a asp-action="Index" class="btn btn-outline-secondary btn-sm">Quay lại</a></div>
<div class="admin-form-card">
    <form asp-action="Them" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="MaNCC" class="form-label"></label><select asp-for="MaNCC" class="form-select" asp-items="ViewBag.NhaCungCaps"></select></div>
            <div class="col-md-6"><label asp-for="MaNV" class="form-label"></label><select asp-for="MaNV" class="form-select" asp-items="ViewBag.NhanViens"></select></div>
            <div class="col-12"><label asp-for="GhiChu" class="form-label"></label><textarea asp-for="GhiChu" class="form-control" rows="2"></textarea></div>
        </div>
        <div class="mt-4"><button type="submit" class="btn btn-admin-primary">Tạo &amp; nhập chi tiết</button></div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }