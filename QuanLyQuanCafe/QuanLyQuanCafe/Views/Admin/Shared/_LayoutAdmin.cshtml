@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var pageTitle = ViewData["Title"]?.ToString() ?? "Bảng điều khiển";
    var hoTen = User.FindFirst("HoTen")?.Value ?? "Quản trị viên";
    var vaiTro = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Quản trị Tooru Coffee</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-sidebar-backdrop d-lg-none" id="adminSidebarBackdrop" aria-hidden="true"></div>
    <div class="admin-shell">
        <aside class="admin-sidebar" id="adminSidebar">
            <a asp-controller="QuanTri" asp-action="Index" class="admin-sidebar-brand">
                <i class="bi bi-cup-hot-fill"></i>
                <span>Tooru Admin</span>
            </a>
            <div class="admin-sidebar-user">
                <i class="bi bi-person-workspace"></i>
                <div class="admin-sidebar-user-text">
                    <div class="fw-semibold">@hoTen</div>
                    <div class="opacity-75">@vaiTro</div>
                </div>
            </div>
            <nav class="admin-nav">
                <div class="admin-nav-section">Tổng quan</div>
                <a asp-controller="QuanTri" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-speedometer2"></i> Bảng điều khiển
                </a>
                <div class="admin-nav-section">Nghiệp vụ</div>
                <a asp-controller="QuanTriSanPham" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-cup-straw"></i> Sản phẩm
                </a>
                <a asp-controller="QuanTriLoaiSanPham" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-tags"></i> Loại SP
                </a>
                <a asp-controller="QuanTri" asp-action="Ban" class="admin-nav-link" data-nav>
                    <i class="bi bi-grid-3x3-gap"></i> Quản lý bàn
                </a>
                <a asp-controller="QuanTriDatBan" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-calendar2-check"></i> Đặt bàn
                </a>
                <a asp-controller="QuanTriHoaDon" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-receipt-cutoff"></i> Hóa đơn
                </a>
                <a asp-controller="QuanTriThanhToan" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-credit-card"></i> Thanh toán
                </a>
                <div class="admin-nav-section">Kho</div>
                <a asp-controller="QuanTriNhaCungCap" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-truck"></i> Nhà cung cấp
                </a>
                <a asp-controller="QuanTriNguyenLieu" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-box-seam"></i> Nguyên liệu
                </a>
                <a asp-controller="QuanTriPhieuNhap" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-box-arrow-in-down"></i> Phiếu nhập
                </a>
                <a asp-controller="QuanTriCongThuc" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-bezier2"></i> Công thức
                </a>
                <a asp-controller="QuanTriKhuyenMai" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-tag"></i> Khuyến mãi
                </a>
                <a asp-controller="QuanTriDanhGia" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-chat-square-heart"></i> Bình luận
                </a>
                <div class="admin-nav-section">Khách &amp; nhân sự</div>
                <a asp-controller="QuanTriKhachHang" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-people"></i> Khách hàng
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="QuanTriNhanVien" asp-action="Index" class="admin-nav-link" data-nav>
                        <i class="bi bi-person-badge"></i> Nhân viên
                    </a>
                    <a asp-controller="QuanTriTaiKhoan" asp-action="Index" class="admin-nav-link" data-nav>
                        <i class="bi bi-key"></i> Tài khoản
                    </a>
                }
                <a asp-controller="QuanTriLichSu" asp-action="Index" class="admin-nav-link" data-nav>
                    <i class="bi bi-clock-history"></i> Lịch sử hoạt động
                </a>
                <hr />
                <a asp-controller="Home" asp-action="Index" class="admin-nav-link" target="_blank" rel="noopener">
                    <i class="bi bi-shop-window"></i> Trang khách
                </a>
            </nav>
        </aside>

        <div class="admin-main-wrap">
            <header class="admin-topbar">
                <div class="admin-topbar-start">
                    <button type="button" class="btn btn-sm btn-outline-secondary d-lg-none" id="adminSidebarToggle" aria-label="Menu">
                        <i class="bi bi-list fs-5"></i>
                    </button>
                    <div>
                        <div class="admin-topbar-eyebrow">Tooru Coffee · Quản trị</div>
                        <h1 class="admin-topbar-title">@pageTitle</h1>
                    </div>
                </div>
                <div class="admin-topbar-end">
                    <span class="admin-topbar-chip"><i class="bi bi-layers"></i> @ctrl</span>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary d-none d-md-inline-flex" target="_blank" rel="noopener">
                        <i class="bi bi-box-arrow-up-right me-1"></i> Xem web
                    </a>
                    <div class="admin-topbar-user d-none d-sm-flex">
                        <i class="bi bi-person-circle"></i>
                        <span>@hoTen</span>
                    </div>
                    <a asp-controller="QuanTri" asp-action="DangXuat" class="btn btn-sm btn-outline-danger admin-btn-logout">
                        <i class="bi bi-box-arrow-right me-1"></i> Đăng xuất
                    </a>
                </div>
            </header>
            <div class="admin-content">
                <div class="admin-alert-slot">
                    <partial name="_Alerts" />
                </div>
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>