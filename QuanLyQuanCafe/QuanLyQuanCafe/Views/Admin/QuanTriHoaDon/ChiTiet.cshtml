@model HoaDon
@using QuanLyQuanCafe.Models
@{
    ViewData["Title"] = "POS #" + Model.MaHD;
    var choTt = Model.TrangThai == "Chờ thanh toán";
    var kms = ViewBag.KhuyenMais as IEnumerable<KhuyenMai> ?? [];
    var phuongThucs = ViewBag.PhuongThucs as string[] ?? PaymentService.PhuongThucThanhToan;
    var tt = ViewBag.ThanhToan as HoaDonThanhToanAdminViewModel ?? new HoaDonThanhToanAdminViewModel { MaHD = Model.MaHD };
}
<div class="admin-page-toolbar">
    <div>
        <h1 class="admin-page-title mb-0">Hóa đơn #@Model.MaHD</h1>
        <p class="text-muted small mb-0">
            @Model.NgayLap.ToString("dd/MM/yyyy HH:mm") · @Model.LoaiDon ·
            @(Model.Ban != null ? "Bàn " + Model.Ban.TenBan : Model.KhachHang?.HoTen ?? Model.TenKhach ?? "Khách lẻ")
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <span class="badge bg-secondary fs-6">@Model.TrangThai</span>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Danh sách</a>
    </div>
</div>

<div class="row g-3 admin-pos-layout">
    <div class="col-lg-8">
        <div class="admin-table-wrap">
            <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
                <h2 class="h6 mb-0 fw-bold">Chi tiết món</h2>
                <span class="text-muted small">@Model.ChiTietHoaDons.Count món</span>
            </div>
            <div class="table-responsive">
                <table class="table admin-table mb-0">
                    <thead><tr><th>Món</th><th>SL</th><th>ĐG</th><th>TT</th><th></th></tr></thead>
                    <tbody>
                        @if (!Model.ChiTietHoaDons.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">Chưa có món — thêm bên dưới</td></tr>
                        }
                        @foreach (var c in Model.ChiTietHoaDons)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@c.SanPham?.TenSP</div>
                                    @if (!string.IsNullOrEmpty(c.GhiChu)) { <div class="small text-muted">@c.GhiChu</div> }
                                </td>
                                <td>@c.SoLuong</td>
                                <td>@c.DonGia.ToString("N0")</td>
                                <td class="price-tag">@c.ThanhTien.ToString("N0")</td>
                                <td>
                                    @if (choTt)
                                    {
                                        <form asp-action="XoaDong" method="post" class="d-inline" onsubmit="return confirm('Xóa dòng?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@Model.MaHD" />
                                            <input type="hidden" name="maCt" value="@c.MaCT" />
                                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (choTt)
        {
            <div class="admin-form-card mt-3">
                <h2 class="h6 fw-bold mb-3"><i class="bi bi-plus-circle me-1"></i> Thêm món</h2>
                <form asp-action="ThemDong" method="post" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.MaHD" />
                    <div class="col-md-5">
                        <label class="form-label">Sản phẩm</label>
                        <select name="MaSP" class="form-select" asp-items="ViewBag.SanPhams" required></select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">SL</label>
                        <input name="SoLuong" type="number" min="1" max="99" value="1" class="form-control" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Ghi chú</label>
                        <input name="GhiChu" class="form-control" placeholder="Ít đá, thêm sữa..." />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-admin-primary w-100">Thêm</button>
                    </div>
                </form>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="admin-form-card mb-3">
            <h2 class="h6 fw-bold mb-3">Tổng cộng</h2>
            <div class="d-flex justify-content-between mb-2"><span>Tạm tính</span><strong>@Model.TongTienTruocGiam.ToString("N0") đ</strong></div>
            <div class="d-flex justify-content-between mb-2 text-success"><span>Giảm giá</span><strong>-@Model.GiamGia.ToString("N0") đ</strong></div>
            @if (Model.KhuyenMai != null)
            {
                <div class="small text-muted mb-2">KM: @Model.KhuyenMai.TenKM</div>
            }
            <hr />
            <div class="d-flex justify-content-between fs-5">
                <span class="fw-bold">Thanh toán</span>
                <span class="price-tag fw-bold">@Model.TongThanhToan.ToString("N0") đ</span>
            </div>
            <p class="small text-muted mt-2 mb-0">NV: @Model.NhanVien?.HoTen</p>
        </div>

        @if (choTt && kms.Any())
        {
            <div class="admin-form-card mb-3">
                <h2 class="h6 fw-bold mb-3"><i class="bi bi-tag me-1"></i> Khuyến mãi</h2>
                @foreach (var km in kms)
                {
                    <form asp-action="ApDungKm" method="post" class="d-flex justify-content-between align-items-center mb-2 gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.MaHD" />
                        <input type="hidden" name="maKm" value="@km.MaKM" />
                        <div class="small flex-grow-1">
                            <div class="fw-semibold">@km.TenKM</div>
                            <div class="text-muted">@(km.LoaiGiam == "PhanTram" ? km.GiaTriGiam + "%" : km.GiaTriGiam.ToString("N0") + "đ") · Tối thiểu @km.DieuKienToiThieu.ToString("N0")</div>
                        </div>
                        <button type="submit" class="btn btn-sm btn-outline-warning" @(Model.MaKM == km.MaKM ? "disabled" : "")>Áp dụng</button>
                    </form>
                }
            </div>
        }

        @if (choTt)
        {
            <div class="admin-form-card mb-3">
                <h2 class="h6 fw-bold mb-3"><i class="bi bi-credit-card me-1"></i> Thanh toán</h2>
                <form asp-action="ThanhToan" asp-route-id="@Model.MaHD" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MaHD" value="@Model.MaHD" />
                    <div class="mb-2">
                        <label class="form-label">Phương thức</label>
                        <select name="PhuongThuc" class="form-select">
                            @foreach (var p in phuongThucs) { <option value="@p">@p</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mã GD (nếu có)</label>
                        <input name="MaGiaoDich" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-admin-primary w-100" @(Model.ChiTietHoaDons.Count == 0 ? "disabled" : "")>
                        <i class="bi bi-check2-circle me-1"></i> Xác nhận TT @Model.TongThanhToan.ToString("N0") đ
                    </button>
                </form>
            </div>

            <form asp-action="Huy" method="post" onsubmit="return confirm('Hủy hóa đơn #@Model.MaHD?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.MaHD" />
                <button type="submit" class="btn btn-outline-danger w-100"><i class="bi bi-x-circle me-1"></i> Hủy hóa đơn</button>
            </form>
        }
        else if (Model.ThanhToan != null)
        {
            <div class="admin-form-card">
                <h2 class="h6 fw-bold mb-2">Đã thanh toán</h2>
                <p class="mb-0 small">@Model.ThanhToan.PhuongThuc · @Model.ThanhToan.SoTien.ToString("N0") đ</p>
                <p class="text-muted small mb-0">@Model.ThanhToan.NgayThanhToan.ToString("dd/MM HH:mm")</p>
            </div>
        }
    </div>
</div>

<style>
.admin-pos-layout .price-tag { color: var(--admin-primary); }
.admin-pos-layout .admin-form-card { background: var(--admin-surface); border-radius: var(--admin-radius); box-shadow: var(--admin-shadow); padding: 1.25rem; }
</style>