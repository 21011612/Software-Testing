@model DatBanAdminViewModel
@{
    var bans = ViewBag.Bans as SelectList;
    var khachs = ViewBag.Khachs as SelectList;
    var trangThais = new[] { "Đã xác nhận", "Đã đến", "Đã hủy", "Hoàn tất", "Quá hạn" };
    var isEdit = Model.MaDatBan > 0;
}
<form asp-action="@(isEdit ? "Sua" : "Them")" method="post">
    @Html.AntiForgeryToken()
    @if (isEdit) { <input type="hidden" asp-for="MaDatBan" /> }
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="row g-3">
        <div class="col-md-6"><label asp-for="MaBan" class="form-label"></label><select asp-for="MaBan" asp-items="bans" class="form-select"></select></div>
        <div class="col-md-6"><label asp-for="MaKH" class="form-label"></label><select asp-for="MaKH" asp-items="khachs" class="form-select"><option value="">— Khách vãng lai —</option></select></div>
        <div class="col-md-6"><label asp-for="TenKhach" class="form-label"></label><input asp-for="TenKhach" class="form-control" /></div>
        <div class="col-md-6"><label asp-for="SDT" class="form-label"></label><input asp-for="SDT" class="form-control" /></div>
        <div class="col-md-4"><label asp-for="NgayDat" class="form-label"></label><input asp-for="NgayDat" class="form-control" type="date" /></div>
        <div class="col-md-4"><label asp-for="GioBatDau" class="form-label"></label><input asp-for="GioBatDau" class="form-control" type="time" /></div>
        <div class="col-md-4"><label asp-for="GioKetThuc" class="form-label"></label><input asp-for="GioKetThuc" class="form-control" type="time" /></div>
        <div class="col-md-4"><label asp-for="SoNguoi" class="form-label"></label><input asp-for="SoNguoi" class="form-control" type="number" min="1" max="30" /></div>
        <div class="col-md-4"><label asp-for="TrangThai" class="form-label"></label><select asp-for="TrangThai" class="form-select">@foreach (var t in trangThais) { <option value="@t">@t</option> }</select></div>
        <div class="col-12"><label asp-for="GhiChu" class="form-label"></label><textarea asp-for="GhiChu" class="form-control" rows="2"></textarea></div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-admin-primary"><i class="bi bi-check-lg me-1"></i> Lưu</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>